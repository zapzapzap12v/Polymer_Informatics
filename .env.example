# Ansys Installation
ANSYS_VERSION=2025.2
ANSYS_EXECUTABLE=C:\Program Files\ANSYS Inc\v252\ANSYS\bin\ansys2025.exe
ANSYS_LICENSE_SERVER=localhost
ANSYS_LICENSE_PORT=1055

# Pipeline Settings
ANSYS_CORE_COUNT=4
ANSYS_MESH_RESOLUTION=Standard
MAX_RETRIES=3
RANDOM_SEED=42

# Directories
WORK_DIR=./
TEMP_DIR=./temp
OUTPUT_DIR=./output
