[flake8]
max-line-length = 100
max-complexity = 15
exclude =
    .git,
    __pycache__,
    .venv,
    venv,
    build,
    dist,
    .eggs,
    *.egg-info,
    tests,
    docs
ignore =
    E203,
    E501,
    W503,
    W504,
    F401
per-file-ignores =
    __init__.py: F401
    tests/*: F401, F811
